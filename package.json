{
  "name": "nipux-local-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A minimal local-first AI workspace with chat, agents, model management, search, usage stats, and an OpenAI-compatible API.",
  "scripts": {
    "setup": "bun run src/cli.ts setup",
    "start": "bun run src/main.ts",
    "local": "bun run src/cli.ts local",
    "dev": "bun --watch src/dev.ts",
    "doctor": "bun run src/cli.ts doctor",
    "preflight": "bun run src/cli.ts preflight",
    "ready": "bun run src/cli.ts readiness",
    "setup:actions": "bun run src/cli.ts setup-actions",
    "install:local": "bun run src/cli.ts install",
    "model:install": "bun run src/cli.ts model-install",
    "media:runtimes": "bun run src/cli.ts media-runtimes",
    "capabilities": "bun run src/cli.ts capabilities",
    "image:backends": "bun run src/cli.ts image-backends",
    "media:defaults": "bun run src/cli.ts media-defaults",
    "worker:image": "bun run src/workers/imageWorker.ts",
    "transcription:install": "bun run src/cli.ts transcription-install",
    "worker:transcription": "bun run src/workers/transcriptionWorker.ts",
    "worker:video": "bun run src/workers/videoWorker.ts",
    "launch:profile": "bun run src/cli.ts launch-profile",
    "launch:write": "bun run src/cli.ts launch-write",
    "browsers:install": "bunx playwright install chromium",
    "package:release": "bun run scripts/package-release.ts",
    "models": "bun run src/cli.ts models",
    "check": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.22",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.2.17"
  }
}
